# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5001

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-task-manager?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://your-frontend-domain.vercel.app

# Google Gemini AI Configuration
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# CORS Configuration (comma-separated URLs)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://ai-smart-task-manager-ten.vercel.app
